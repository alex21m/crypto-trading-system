# Binance API (futures-enabled keys)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_secret_key_here

# OKX API
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET=your_okx_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# Redis
REDIS_URL=redis://redis:6379/0

# TimescaleDB / PostgreSQL
DATABASE_URL=postgresql://trader:password@timescaledb:5432/cryptodb

# App
SECRET_KEY=change_this_to_random_string_64chars
FLASK_ENV=production
PORT=5000

# Trading
PAPER_TRADING=true
BINANCE_TESTNET=true
MAX_POSITION_SIZE_PCT=5
DEFAULT_LEVERAGE=10
MAX_DAILY_LOSS_PCT=3

# Pro Version Settings
MIN_CONFIDENCE=70
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
STRATEGY=ai
